DESCRIPTION UltimaX Terrain Texture Generator
EXPORTS

	;------------------------------
	;-- Height Map Exports
	;------------------------------
	 HeightMap_PreLoad			 @1
	 HeightMap_FinalizeLoad		 @2
	 HeightMap_GetExtent		 @3
	 HeightMap_CreateRoughMap	 @4
	 HeightMap_CreateShadeMap	 @5
	 HeightMap_RenderMap		 @6
	 HeightMap_BlendWithShadeMap @7
	 HeightMap_Cleanup		     @8